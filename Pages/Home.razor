@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4">
                <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=miguelo" class="rounded-circle mb-3"
                     width="120" />
                <h3>Paulo Andre</h3>
                <p class="text-muted">Estudante</p>
            </div>
        </div>

        <div class="col-lg-8">
            <h2 class="mb-4">Experiência Profissional</h2>
            
            @foreach (var exp in MinhasExperiencias)
            {
                <ExperienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia {
            Empresa = "Centro Universitário UNA",
            Cargo = "Estudante",
            Inicio = "2026",
            Descricao = "Cursando Analise e Desenvolvimento de sistemas."
        },
        new Experiencia {
            Empresa = "Comercia Elohim",
            Cargo = "Atendente",
            Inicio = "2022",
            Descricao = "Estoquista, Balconista Lanço cartão quase um faz tudo"
        }
    };
}